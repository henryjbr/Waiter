{
  "name": "com.waiter.app",
  "displayName": "Waiter",
  "version": "1.0.0",
  "description": "Aplicativo Android do Waiter.",
  "main": "index.js",
  "scripts": {
    "sync:web": "npm --prefix .. run build && node scripts/sync-web.js",
    "check:web": "node --check ../src/script.js && node --check ../src/supabase-config.js",
    "android:check": "cordova requirements android",
    "android:ensure": "node scripts/ensure-android.js",
    "android:prepare": "npm run sync:web && npm run android:ensure && cordova prepare android",
    "android:build": "npm run sync:web && npm run android:ensure && cordova build android --debug",
    "android:release": "npm run sync:web && npm run android:ensure && cordova build android --release",
    "test": "npm run check:web"
  },
  "keywords": [
    "ecosystem:cordova"
  ],
  "author": "Waiter",
  "license": "Apache-2.0",
  "devDependencies": {
    "cordova": "13.0.0",
    "cordova-android": "15.0.0"
  },
  "cordova": {
    "platforms": [
      "android"
    ]
  }
}
